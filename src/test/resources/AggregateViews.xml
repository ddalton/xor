	<aggregateView>
		<name>ARTIFACTINFO</name>
		<attributeList>[BASICINFO]</attributeList>		
		<attributeList>ownedBy.name</attributeList>
		<attributeList>state.name</attributeList>
		<attributeList>metaEntityType.name</attributeList>
